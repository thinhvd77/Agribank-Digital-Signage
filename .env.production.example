# Production environment — copy to .env on the Windows Server and edit values

# Database (adjust user/password/host for your PostgreSQL install)
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/digital_signage"

# Server
PORT=3000
NODE_ENV=production

# JWT — MUST be a random 32+ character string in production
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="REPLACE_WITH_RANDOM_SECRET"
JWT_EXPIRES_IN="24h"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_VIDEO=524288000
MAX_FILE_SIZE_IMAGE=10485760
