# Docker Offline Deployment Environment
# Copy this file to .env.docker.offline and update secrets before running compose.

# Optional image tag override used by docker-compose.offline.yml
APP_IMAGE=agribank-digital-signage:1.0.0

# PostgreSQL chạy trên host machine (không chạy trong container)
# - Docker Desktop (Windows/macOS): host.docker.internal hoạt động mặc định
# - Linux Engine: compose đã thêm extra_hosts host-gateway
DATABASE_URL="postgresql://postgres:CHANGE_ME@host.docker.internal:5432/digital_signage"

PORT=3000
NODE_ENV=production

# Bắt buộc đổi secret ở môi trường thật
JWT_SECRET="REPLACE_WITH_RANDOM_SECRET"
JWT_EXPIRES_IN="24h"

UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_VIDEO=524288000
MAX_FILE_SIZE_IMAGE=10485760