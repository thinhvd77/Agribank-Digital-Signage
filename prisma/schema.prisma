// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ScreenStatus {
  online
  offline
}

enum MediaType {
  video
  image
}

enum UserRole {
  admin
  screen_manager
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(admin)
  screenId     String?   @unique @map("screen_id")
  screen       Screen?   @relation("ScreenManager", fields: [screenId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Screen {
  id              String         @id @default(uuid())
  name            String
  location        String?
  resolution      String?
  deletedAt       DateTime?      @map("deleted_at")
  activeProfileId String?        @map("active_profile_id")
  status          ScreenStatus   @default(offline)
  lastPing        DateTime?      @map("last_ping")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  profiles        Profile[]      @relation("ScreenProfiles")
  activeProfile   Profile?       @relation("ActiveProfile", fields: [activeProfileId], references: [id], onDelete: SetNull)
  manager         User?          @relation("ScreenManager")

  @@index([status])
  @@index([activeProfileId])
  @@index([deletedAt])
  @@map("screens")
}

model Profile {
  id               String         @id @default(uuid())
  screenId         String         @map("screen_id")
  name             String
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  screen           Screen         @relation("ScreenProfiles", fields: [screenId], references: [id], onDelete: Cascade)
  activeInScreens  Screen[]       @relation("ActiveProfile")
  playlistItems    PlaylistItem[]

  @@unique([screenId, name])
  @@index([screenId])
  @@map("profiles")
}

model Media {
  id           String         @id @default(uuid())
  filename     String
  originalName String         @map("original_name")
  filePath     String         @map("file_path")
  fileType     MediaType      @map("file_type")
  fileSize     BigInt         @map("file_size")
  mimeType     String?        @map("mime_type")
  duration     Int?
  dimensions   String?
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  playlistItems PlaylistItem[]

  @@index([fileType])
  @@index([createdAt(sort: Desc)])
  @@map("media")
}

model PlaylistItem {
  id         String   @id @default(uuid())
  profileId  String   @map("profile_id")
  mediaId    String   @map("media_id")
  orderIndex Int      @map("order_index")
  duration   Int      @default(10)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  media      Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([profileId, orderIndex])
  @@index([profileId])
  @@index([profileId, orderIndex])
  @@map("playlist_items")
}
